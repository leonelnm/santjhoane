---
import { useTranslations, useTranslatedPath } from "../i18n/utils";

const lang = Astro.currentLocale ?? "es";
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const data = {
  title: "Restaurante Sant Jhoane",
  description: t("hero.description"),
  url_video_placeholder:
    "https://cdn.jsdelivr.net/gh/leonelnm/assets@main/public/video/video-placeholder-santjhoane.mp4",
  url_map: "https://maps.app.goo.gl/fPTwu5DGyFdq1csG7",
  url_phone: "tel:+34960151265",
};
---

<section
  id="hero-section"
  class="relative h-screen flex items-center justify-center overflow-hidden"
>
  <!-- Language Switcher -->
  <div
    class="absolute top-4 right-4 z-20 flex gap-1 bg-black/40 backdrop-blur-md rounded-full border border-white/10 p-1"
  >
    <a
      href={translatePath("/", "es")}
      class={`px-3 py-1.5 text-xs font-bold rounded-full transition-all duration-300 ${lang === "es" ? "bg-amber-600 text-white" : "text-gray-400 hover:text-white"}`}
      aria-label="Español"
    >
      ES
    </a>
    <a
      href={translatePath("/", "en")}
      class={`px-3 py-1.5 text-xs font-bold rounded-full transition-all duration-300 ${lang === "en" ? "bg-amber-600 text-white" : "text-gray-400 hover:text-white"}`}
      aria-label="English"
    >
      EN
    </a>
  </div>
  <video
    id="hero-video"
    autoplay
    loop
    muted
    playsinline
    aria-label={t("hero.video-aria")}
    class="absolute inset-0 object-cover w-full h-full opacity-60"
  >
    <source src={data.url_video_placeholder} type="video/mp4" />
    {t("hero.video-fallback")}
  </video>

  <!-- Gradient Overlay -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/20 to-[#0a0a0a]"
  >
  </div>

  <div
    class="relative z-10 text-center text-white px-8 md:px-4 py-4 w-full md:max-w-4xl mx-auto flex flex-col items-center"
  >
    <h1
      class="text-4xl md:text-6xl font-black mb-6 tracking-tight font-['Syne'] leading-tight"
    >
      SANT <span class="text-amber-600">JHOAN'E</span><br />
      <span class="text-2xl md:text-4xl font-normal text-white/90"
        >{t("hero.subtitle")}</span
      >
    </h1>
    <p
      class="text-xl md:text-2xl mb-10 font-light tracking-wide text-gray-200 max-w-2xl"
    >
      {data.description}
    </p>

    <div
      class="flex flex-col sm:flex-row gap-4 justify-center w-full sm:w-auto"
    >
      <a
        href={data.url_map}
        target="_blank"
        class="glass px-8 py-4 rounded-full text-lg font-bold hover:bg-white/10 transition duration-300 border border-white/20 backdrop-blur-md"
      >
        {t("hero.get-there")}
      </a>
      <a
        href={translatePath("/carta")}
        class="bg-amber-700 text-white px-8 py-4 rounded-full text-lg font-bold hover:bg-amber-600 transition duration-300 shadow-lg shadow-amber-900/50"
      >
        {t("hero.view-menu")}
      </a>
    </div>
  </div>

  <!-- Scroll Indicator -->
  <div
    class="absolute bottom-10 left-1/2 transform -translate-x-1/2 animate-bounce"
  >
    <svg
      class="w-6 h-6 text-white/50"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>
