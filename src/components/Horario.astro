---
import { useTranslations } from "../i18n/utils";

const t = useTranslations(Astro.currentLocale ?? "es");

const days = [
  { key: "hours.mon", open: "09:00", close: "21:15" },
  { key: "hours.tue", open: "09:00", close: "21:15" },
  { key: "hours.wed", open: "09:00", close: "21:15" },
  { key: "hours.thu", open: "09:00", close: "21:15" },
  { key: "hours.fri", open: "09:00", close: "21:15" },
  { key: "hours.sat", open: "09:00", close: "21:15" },
  { key: "hours.sun", open: "09:00", close: "19:15" },
];
---

<section class="py-20 px-4 relative overflow-hidden">
  <!-- Background Elements -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-amber-900/20 rounded-full blur-[100px] -z-10"
  >
  </div>

  <div class="max-w-4xl mx-auto relative z-10">
    <div class="text-center mb-12">
      <h2 class="text-4xl md:text-5xl font-bold text-white font-['Syne'] mb-4">
        {t("hours.title")}
      </h2>
      <p class="text-gray-400 font-['Outfit']">
        {t("hours.subtitle")}
      </p>
    </div>

    <div
      class="glass p-8 md:p-12 rounded-3xl border border-white/10 shadow-2xl relative overflow-hidden group"
    >
      <div
        class="absolute top-0 right-0 p-8 opacity-10 group-hover:opacity-20 transition duration-500"
      >
        <svg
          class="w-32 h-32 text-amber-500"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1"
            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
      </div>

      <ul class="space-y-4 relative z-10">
        {
          days.map((item) => (
            <li class="flex justify-between items-center border-b border-white/5 pb-4 last:border-0 last:pb-0 hover:bg-white/5 p-2 rounded-lg transition duration-300">
              <span class="text-lg md:text-xl font-bold text-gray-200 font-['Syne']">
                {t(item.key as any)}
              </span>
              <div class="flex items-center gap-3">
                <span class="text-amber-500 font-['Outfit'] font-semibold">
                  {item.open}
                </span>
                <span class="text-gray-600">-</span>
                <span class="text-amber-500 font-['Outfit'] font-semibold">
                  {item.close}
                </span>
              </div>
            </li>
          ))
        }
      </ul>

      <div class="mt-8 text-center pt-6 border-t border-white/10">
        <p class="text-sm text-gray-400 font-['Outfit']">
          {t("hours.note")}
        </p>
      </div>
    </div>
  </div>
</section>
