---
import { useTranslations } from "../i18n/utils";

const year = new Date().getFullYear();
const t = useTranslations(Astro.currentLocale ?? "es");
---

<footer
  class="border-t border-white/5 bg-[#050505] text-gray-400 pb-12 pt-20 px-4"
>
  <div class="max-w-6xl mx-auto text-center flex flex-col items-center gap-4">
    <p class="font-['Syne'] text-lg font-bold text-white">
      {t("footer.brand")}
    </p>
    <p class="text-sm">&copy; {year} {t("footer.copyright").replace("{year}", String(year))}</p>
  </div>
</footer>
