---
import Footer from "../../components/Footer.astro";
import MejoresPlatos from "../../components/MejoresPlatos/MejoresPlatos.astro";
import Horario from "../../components/Horario.astro";
import Layout from "../../layouts/Layout.astro";
import HeroVideo from "../../components/HeroVideo.astro";
import ContactoIcons from "../../components/ContactoIcons.astro";
import JsonLD from "../../components/JsonLD.astro";
import FAQ from "../../components/FAQ.astro";
import { info } from "../../api/info";
import { useTranslations } from "../../i18n/utils";
import { getFaqList } from "../../api/faq";
import { getFeaturedPlatos } from "../../api/platos";

const lang = Astro.currentLocale ?? "en";
const t = useTranslations(lang);
const featured = await getFeaturedPlatos(lang as Lang);
const menuItems = featured.map((plato) => ({
  "@type": "MenuItem",
  name: plato.name,
  description: plato.ingredients,
}));
const faqItems = getFaqList(lang as Lang);
---

<Layout title={t("site.title")} description={t("site.description")}>
  <JsonLD
    slot="head-jsonld"
    data={{
      "@context": "https://schema.org",
      "@type": "Restaurant",
      ...info,
      image: [`${info.url}/favicon.webp`],
      hasMenu: {
        "@type": "Menu",
        name: t("jsonld.featured-name"),
        hasMenuSection: [
          {
            "@type": "MenuSection",
            name: t("jsonld.featured-section"),
            hasMenuItem: menuItems,
          },
        ],
      },
    }}
  />
  <main class="min-h-screen bg-[#0a0a0a]">
    <HeroVideo />
    <MejoresPlatos />
    <ContactoIcons />
    <Horario />
    <FAQ items={faqItems} />
    <Footer />
  </main>
</Layout>
